# Local sandbox example only.
# Copy this file to services/nb-bond-api/.env for direct `npm run dev` or
# `npm start` usage outside the Helm deployment path.
# Replace any secret placeholders with local-only sandbox values.
# Never commit or reuse real private keys outside local development.

RPC_URL=
GLOBAL_REGISTRY_ADDRESS=
BOND_MANAGER_CONTRACT_NAME="Bond Manager"
BOND_ADMIN_PK=

# Optional - leave blank for generated
#AUCTION_OWNER_SEAL_PK=

# Optional defaults
#LOG_LEVEL=info
#EXPRESS_PORT=8080

#DB_PATH=data/ingestion.sqlite
#START_BLOCK=0
#POLL_INTERVAL_MS=3000
