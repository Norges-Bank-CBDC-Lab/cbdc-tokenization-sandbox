# Local sandbox example only.
# Copy this file to contracts/.env before running ./sandbox.sh start,
# ./contracts.sh start, ./contracts.sh verify, or ./deploy.sh.
# Replace every PK_* placeholder with a local-only sandbox private key.
# Never commit or reuse real private keys outside local development.

ANVIL_RPC_URL=http://127.0.0.1:8545
BESU_LOCAL_RPC_URL=http://besu.cbdc-sandbox.local:8545
BLOCKSCOUT_LOCAL_URL=http://blockscout.cbdc-sandbox.local:80/api/
NB_BOND_API_URL=http://bond-api.cbdc-sandbox.local
FOUNDRY_DISABLE_NIGHTLY_WARNING=1

# Replace each placeholder with the private key for the noted local sandbox address.
# These addresses match the historical deterministic demo setup, but the keys are
# intentionally not provided in the public repository.

# 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
